# ─── Required for production (RapidAPI security) ─────────────────────────────
# Found in RapidAPI dashboard → My APIs → [your API] → Security → Proxy Secret
RAPIDAPI_PROXY_SECRET=your_rapidapi_proxy_secret_here

# ─── Optional: direct-access key (skip RapidAPI, for testing) ────────────────
INTERNAL_API_KEY=your_internal_dev_key_here

# ─── API 4: News Sentiment ────────────────────────────────────────────────────
# Free at https://newsapi.org  (100 requests/day on free tier)
NEWS_API_KEY=your_newsapi_key_here

# HuggingFace for RoBERTa sentiment model (free at https://huggingface.co/settings/tokens)
# If not set, falls back to keyword-based sentiment (still works, less accurate)
HUGGINGFACE_API_KEY=your_huggingface_token_here

# ─── API 5: Cricket Fantasy Stats ────────────────────────────────────────────
# Free at https://cricapi.com  (500 requests/day on free tier)
# If not set, falls back to ESPN Cricinfo scraping (limited features)
CRICKET_API_KEY=your_cricapi_key_here

# ─── Optional upgrades ───────────────────────────────────────────────────────
# CoinGecko Pro key (not required — free tier works, Pro removes rate limits)
COINGECKO_API_KEY=
